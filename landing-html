.feature-card:hover{background:rgba(99,102,241,0.1);border-color:rgba(99,102,241,0.3)}
.feature-icon{font-size:28px;margin-bottom:10px}
.feature-title{font-weight:700;font-size:16px;margin-bottom:6px;color:#f1f5f9}
.feature-desc{font-size:14px;color:#94a3b8;line-height:1.5}
.ba-row{display:grid;grid-template-columns:1fr auto 1fr;gap:12px;align-items:center;margin-bottom:12px}
.ba-before{background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.15);border-radius:12px;padding:14px 16px;font-size:13px;color:#fca5a5;line-height:1.4}
.ba-arrow{font-size:18px;color:#6366f1;font-weight:700;text-align:center}
.ba-after{background:rgba(34,197,94,0.08);border:1px solid rgba(34,197,94,0.15);border-radius:12px;padding:14px 16px;font-size:13px;color:#86efac;line-height:1.4}
.ba-x{font-weight:700;color:#f87171}
.ba-check{font-weight:700;color:#4ade80}
.arch-flow{display:flex;align-items:center;justify-content:center;gap:8px;flex-wrap:wrap;padding:0 10px}
.arch-box{background:rgba(255,255,255,0.03);border-radius:12px;padding:16px 18px;text-align:center;flex:1 1 140px;max-width:180px}
.arch-label{font-weight:700;font-size:14px;margin-bottom:4px}
.arch-sub{font-size:11px;color:#64748b;line-height:1.3}
.arch-arrow{color:#475569;font-size:22px;font-weight:700}
.arch-subtitle{text-align:center;color:#64748b;font-size:14px;margin-bottom:28px}
.cta-section{padding:48px 24px 60px;text-align:center}
