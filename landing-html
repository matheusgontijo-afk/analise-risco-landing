.btn-secondary{background:transparent;color:#818cf8;border:1px solid rgba(99,102,241,0.4);border-radius:10px;padding:14px 32px;font-size:15px;font-weight:600;cursor:pointer;text-decoration:none;display:inline-block}
.footer{border-top:1px solid rgba(255,255,255,0.06);padding:20px 24px;text-align:center;font-size:12px;color:#475569}
@media(max-width:640px){.ba-row{grid-template-columns:1fr}.ba-arrow{display:none}.arch-flow{flex-direction:column}.arch-arrow{transform:rotate(90deg)}}
