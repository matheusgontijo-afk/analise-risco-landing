h1{font-size:clamp(28px,5vw,48px);font-weight:800;line-height:1.1;margin:0 auto 16px;max-width:700px;background:linear-gradient(135deg,#fff 30%,#818cf8 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
