.video-container{position:relative;padding-bottom:56.25%;height:0}
.video-container iframe{position:absolute;top:0;left:0;width:100%;height:100%;border:none;border-radius:16px}
.video-caption{text-align:center;color:#64748b;font-size:13px;margin-top:12px}
.section{padding:40px 24px;max-width:800px;margin:0 auto}
.section h2{font-size:24px;font-weight:700;text-align:center;margin-bottom:32px;color:#f1f5f9}
.features-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:16px}
